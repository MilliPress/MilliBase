{
    "name": "millipress/millibase",
    "description": "Declarative WordPress settings framework. Define your settings page in PHP arrays — sections, fields, tabs, validation — and get a React UI automatically.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Philipp Wellmer",
            "email": "hello@millipress.com"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.0",
        "php-stubs/wordpress-stubs": "^6.0",
        "phpstan/phpstan": "@stable",
        "phpstan/extension-installer": "^1.3",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "pestphp/pest": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "MilliBase\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MilliBase\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "composer test:lint && composer test:phpstan && composer test:unit",
        "test:unit": "pest --colors=always",
        "test:phpstan": "phpstan analyse -c phpstan.neon --memory-limit 1G",
        "test:lint": "phpcs -s",
        "test:fix": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "pestphp/pest-plugin": true
        }
    }
}
